{
  "name": "encantia",
  "publisher": "ChristopherClopezv",
  "displayName": "Encantia",
  "description": "Lenguaje encantia",
  "version": "0.0.4",
  "icon": "encantia.png",
  "engines": {
    "vscode": "^1.108.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
  "onCommand:encantia.run",
  "onLanguage:encantia"
],
  "main": "./dist/extension.js",
  "contributes": {

     "commands": [
    {
      "command": "encantia.run",
      "title": "▶ Run Encantia"
    }],
    
    "languages": [
  {
    "id": "encantia",
    "aliases": ["Encantia", "encantia"],
    "extensions": [".encantia"],
    "configuration": "./language-configuration.json"
  }
],

"grammars": [
  {
    "language": "encantia",
    "scopeName": "source.encantia",
    "path": "./syntaxes/encantia.tmLanguage.json"
  }
],
  "menus": {
    "editor/title": [
      {
        "command": "encantia.run",
        "when": "resourceExtname == .encantia",
        "group": "navigation"
      }
    ]
  }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.108.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "ts-loader": "^9.5.4",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
