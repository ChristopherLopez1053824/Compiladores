{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Encantia",
  "scopeName": "source.encantia",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#chars"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#booleans"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.encantia",
          "match": "//.*$"
        },
        {
          "name": "comment.block.encantia",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.encantia",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.encantia",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "chars": {
      "patterns": [
        {
          "name": "string.quoted.single.encantia",
          "match": "'[^']*'"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.encantia",
          "match": "\\b(convoca|comienza|hechizo|destino|alterno|guardian|viaje|felices|Divulga|escuchar)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.encantia",
          "match": "\\b(intenso|fenix|dorado|chispa|bondad|Cancion|vasto)\\b"
        }
      ]
    },
    "booleans": {
      "patterns": [
        {
          "name": "constant.language.boolean.encantia",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.encantia",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.encantia",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.encantia",
          "match": "\\b[a-zA-Z_][a-zA-Z_0-9]*(?=\\s*\\()"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.encantia",
          "match": "==|!=|<=|>=|&&|\\|\\||[=+\\-*/<>]"
        }
      ]
    }
  }
}